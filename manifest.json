<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1">
<title>Password Manager</title>
<meta name="description" content="A private, offline password manager with local AES-GCM encryption.">

<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#0A0E17">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Passwords">
<meta name="mobile-web-app-capable" content="yes">
<link rel="apple-touch-icon" href="icons/icon-180.png">
<link rel="icon" href="icons/favicon-32.png" sizes="32x32">
<link rel="stylesheet" href="css/style.css">
</head>
<body>

<!-- =========================================================
     Icon sprite (all icons are inline stroke-based SVG symbols)
     ========================================================= -->
<svg xmlns="http://www.w3.org/2000/svg" class="hidden" aria-hidden="true">
<defs>
<g id="ic-shield" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M12 2 4 5v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V5l-8-3Z"/>
  <path d="M9 12.2l2 2 4-4.4"/>
</g>
<g id="ic-search" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <circle cx="10.5" cy="10.5" r="6.5"/><path d="M20 20l-4.8-4.8"/>
</g>
<g id="ic-plus" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M12 5v14M5 12h14"/>
</g>
<g id="ic-grid" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <rect x="3.5" y="3.5" width="7" height="7" rx="1.6"/><rect x="13.5" y="3.5" width="7" height="7" rx="1.6"/>
  <rect x="3.5" y="13.5" width="7" height="7" rx="1.6"/><rect x="13.5" y="13.5" width="7" height="7" rx="1.6"/>
</g>
<g id="ic-gear" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <circle cx="12" cy="12" r="3.2"/>
  <path d="M19.4 13.5a1.7 1.7 0 000-3l1-1.6-1.7-1.7-1.7 1a1.7 1.7 0 00-3-1.3L14 4.6h-2.4L11.4 7a1.7 1.7 0 00-3 1.3l-1.7-1L5 9l1 1.6a1.7 1.7 0 000 3L5 15.2l1.7 1.7 1.7-1a1.7 1.7 0 003 1.3l.2 2.2H14l.2-2.2a1.7 1.7 0 003-1.3l1.7 1 1.7-1.7-1-1.6Z"/>
</g>
<g id="ic-chevron-right" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M9 5l7 7-7 7"/>
</g>
<g id="ic-chevron-left" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M15 5l-7 7 7 7"/>
</g>
<g id="ic-close" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M6 6l12 12M18 6L6 18"/>
</g>
<g id="ic-edit" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M16.5 3.5a2.1 2.1 0 013 3L7 19l-4 1 1-4 12.5-12.5Z"/>
</g>
<g id="ic-trash" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M4 7h16M9 7V4.8c0-.7.6-1.3 1.3-1.3h3.4c.7 0 1.3.6 1.3 1.3V7M6 7l1 12.3c0 .9.8 1.7 1.7 1.7h6.6c.9 0 1.7-.8 1.7-1.7L18 7"/>
  <path d="M10 11v6M14 11v6"/>
</g>
<g id="ic-lock" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <rect x="4.5" y="10.5" width="15" height="10" rx="2.2"/>
  <path d="M7.5 10.5V7a4.5 4.5 0 019 0v3.5"/>
</g>
<g id="ic-copy" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <rect x="8.5" y="8.5" width="11" height="11" rx="2"/>
  <path d="M15 8.5V6.2A2.2 2.2 0 0012.8 4H6.2A2.2 2.2 0 004 6.2v6.6A2.2 2.2 0 006.2 15H8.5"/>
</g>
<g id="ic-eye" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z"/>
  <circle cx="12" cy="12" r="3"/>
</g>
<g id="ic-eye-off" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M3 3l18 18"/>
  <path d="M10.6 5.6A10.7 10.7 0 0112 5.5c6 0 9.5 6.5 9.5 6.5a13.6 13.6 0 01-3 3.7M6.5 7.4C4 9.1 2.5 12 2.5 12S6 18.5 12 18.5a9.9 9.9 0 004-.8"/>
  <path d="M9.9 10a3 3 0 004.1 4.1"/>
</g>
<g id="ic-warning" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M12 3.5 2.5 20h19L12 3.5Z"/><path d="M12 9.5v4.2"/><circle cx="12" cy="16.8" r="0.15" fill="currentColor"/>
</g>
<g id="ic-info" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <circle cx="12" cy="12" r="9"/><path d="M12 11v5.5"/><circle cx="12" cy="7.8" r="0.15" fill="currentColor"/>
</g>
<g id="ic-check" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
  <path d="M4.5 12.5l5 5 10-11"/>
</g>
<g id="ic-key" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <circle cx="7.5" cy="14.5" r="4"/><path d="M10.5 11.5 20 2M16.5 5.5l2.5 2.5M13.5 8.5 15.5 10.5"/>
</g>
<g id="ic-refresh" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M20 11A8 8 0 006.3 6.3L4 8.6M4 13a8 8 0 0013.7 4.7L20 15.4"/>
  <path d="M4 4.5v4.1h4.1M20 19.5v-4.1h-4.1"/>
</g>
<g id="ic-download" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M12 3.5v11M7.5 10l4.5 4.5L16.5 10"/><path d="M4.5 18.5h15"/>
</g>
<g id="ic-upload" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M12 14.5v-11M7.5 8l4.5-4.5L16.5 8"/><path d="M4.5 18.5h15"/>
</g>
<g id="ic-image" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <rect x="3.5" y="4.5" width="17" height="15" rx="2.2"/><circle cx="9" cy="10" r="1.6"/><path d="M4 17l5-4.5 3 2.5 3.5-3.5L20 16"/>
</g>
<g id="ic-globe" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.7 3.8 6 3.8 9s-1.3 6.3-3.8 9c-2.5-2.7-3.8-6-3.8-9s1.3-6.3 3.8-9Z"/>
</g>
<g id="ic-folder" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M3.5 6.8c0-1 .8-1.8 1.8-1.8h4l2 2.2h7.4c1 0 1.8.8 1.8 1.8v8.4c0 1-.8 1.8-1.8 1.8H5.3c-1 0-1.8-.8-1.8-1.8V6.8Z"/>
</g>
<g id="ic-note" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M6 3.5h9l4.5 4.5V19a1.5 1.5 0 01-1.5 1.5H6A1.5 1.5 0 014.5 19V5A1.5 1.5 0 016 3.5Z"/>
  <path d="M14.5 3.5V8H19M8 12h8M8 15.5h5"/>
</g>
<g id="ic-clock" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <circle cx="12" cy="12" r="9"/><path d="M12 7v5.3l3.6 2.1"/>
</g>
<g id="ic-arrow-right" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M4 12h16M14 6l6 6-6 6"/>
</g>
<g id="ic-tag" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M12 3.5h5.4c.6 0 1.1.5 1.1 1.1V10c0 .3-.1.6-.4.8l-9 9a1.1 1.1 0 01-1.6 0l-6-6a1.1 1.1 0 010-1.6l9-9c.2-.2.5-.4.8-.4Z"/>
  <circle cx="15.5" cy="7.5" r="1.3"/>
</g>
<g id="ic-wifi-lock" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <path d="M5 9.5a11 11 0 0114 0M8 13a6.5 6.5 0 018 0"/>
  <rect x="9.5" y="15.5" width="9" height="7" rx="1.6"/><path d="M11.5 15.5v-1.7a2.5 2.5 0 015 0v1.7"/>
</g>
</defs>
</svg>

<div id="app">

  <!-- ================= SPLASH ================= -->
  <section id="screen-splash" class="screen screen--centered" data-hide-nav>
    <div class="splash">
      <img src="icons/icon-192.png" alt="Password Manager">
      <div class="spinner" role="status" aria-label="Loading"></div>
    </div>
  </section>

  <!-- ================= SETUP (first launch) ================= -->
  <section id="screen-setup" class="screen screen--centered" hidden data-hide-nav>
    <div class="lock-shield"><svg><use href="#ic-shield"/></svg></div>
    <h1 class="lock-title">Create a Master Password</h1>
    <p class="lock-subtitle">This unlocks your vault and encrypts every item inside it. Choose something only you know.</p>

    <div class="callout callout--warning">
      <svg><use href="#ic-warning"/></svg>
      <p><strong>There is no password reset.</strong> If this password is lost, everything stored in the vault is permanently unreadable.</p>
    </div>

    <form id="form-setup" novalidate>
      <div class="field">
        <label class="field__label" for="setup-password">Master password</label>
        <div class="field__control">
          <input class="input input--with-icon" id="setup-password" type="password" autocomplete="new-password" placeholder="Enter a strong password" required>
          <button type="button" class="field__icon-btn" data-toggle-visibility="setup-password" aria-label="Show password">
            <svg><use href="#ic-eye"/></svg>
          </button>
        </div>
        <div class="strength-meter" id="setup-strength-meter">
          <div class="strength-meter__seg"></div><div class="strength-meter__seg"></div>
          <div class="strength-meter__seg"></div><div class="strength-meter__seg"></div>
        </div>
        <div class="strength-label"><span id="setup-strength-label">Strength</span><span id="setup-strength-hint"></span></div>
      </div>

      <div class="field">
        <label class="field__label" for="setup-password-confirm">Confirm password</label>
        <div class="field__control">
          <input class="input input--with-icon" id="setup-password-confirm" type="password" autocomplete="new-password" placeholder="Re-enter your password" required>
          <button type="button" class="field__icon-btn" data-toggle-visibility="setup-password-confirm" aria-label="Show password">
            <svg><use href="#ic-eye"/></svg>
          </button>
        </div>
        <div class="field__error" id="setup-error">Passwords do not match.</div>
      </div>

      <button type="submit" class="btn btn-primary" style="margin-top:6px;">Create Vault</button>
    </form>
  </section>

  <!-- ================= UNLOCK ================= -->
  <section id="screen-unlock" class="screen screen--centered" hidden data-hide-nav>
    <div class="lock-shield"><svg><use href="#ic-lock"/></svg></div>
    <h1 class="lock-title">Vault Locked</h1>
    <p class="lock-subtitle">Enter your master password to unlock.</p>

    <form id="form-unlock" novalidate>
      <div class="field">
        <label class="field__label" for="unlock-password">Master password</label>
        <div class="field__control">
          <input class="input input--with-icon" id="unlock-password" type="password" autocomplete="current-password" placeholder="Master password" required>
          <button type="button" class="field__icon-btn" data-toggle-visibility="unlock-password" aria-label="Show password">
            <svg><use href="#ic-eye"/></svg>
          </button>
        </div>
        <div class="field__error" id="unlock-error">Incorrect master password.</div>
      </div>
      <button type="submit" class="btn btn-primary">Unlock</button>
    </form>

    <button type="button" class="btn btn-ghost" id="btn-forgot-password" style="margin-top:10px;">Forgot your master password?</button>
  </section>

  <!-- ================= VAULT ================= -->
  <section id="screen-vault" class="screen" hidden>
    <div class="topbar">
      <div>
        <h1 class="topbar__title">Vault</h1>
        <p class="topbar__subtitle" id="vault-count-label">0 passwords</p>
      </div>
      <div class="topbar__actions">
        <button class="icon-btn" id="btn-lock-vault" aria-label="Lock vault"><svg><use href="#ic-lock"/></svg></button>
      </div>
    </div>

    <div class="search-bar glass">
      <svg><use href="#ic-search"/></svg>
      <input type="text" id="vault-search" placeholder="Search passwords">
    </div>

    <div class="chip-row" id="vault-category-chips"></div>

    <div id="vault-recent-section">
      <p class="section-label">Recently Added</p>
      <div class="entry-list" id="vault-recent-list"></div>
    </div>

    <div id="vault-all-section">
      <p class="section-label">All Items</p>
      <div class="entry-list" id="vault-all-list"></div>
    </div>

    <div class="empty-state" id="vault-empty" hidden>
      <div class="empty-state__icon"><svg><use href="#ic-key"/></svg></div>
      <h2 class="empty-state__title">No saved passwords</h2>
      <p class="empty-state__text">Add your first login to start building your private vault.</p>
      <button class="btn btn-primary" id="btn-empty-add" style="width:auto;padding-left:24px;padding-right:24px;">Add Password</button>
    </div>

    <footer class="app-footer" data-footer></footer>
  </section>

  <!-- ================= ADD / EDIT PASSWORD ================= -->
  <section id="screen-add" class="screen" hidden data-hide-nav>
    <div class="topbar">
      <button class="icon-btn" id="btn-add-cancel" aria-label="Close"><svg><use href="#ic-close"/></svg></button>
      <h1 class="topbar__title" id="add-screen-title" style="font-size:19px;">Add Password</h1>
      <div style="width:40px;"></div>
    </div>

    <form id="form-add" novalidate>
      <input type="hidden" id="add-entry-id">

      <div class="field">
        <label class="field__label" for="add-site-name">Website name</label>
        <input class="input" id="add-site-name" type="text" placeholder="e.g. Instagram" required>
      </div>

      <div class="field">
        <label class="field__label" for="add-site-url">Website URL</label>
        <input class="input" id="add-site-url" type="text" placeholder="e.g. instagram.com">
      </div>

      <div class="field">
        <label class="field__label" for="add-username">Username / email</label>
        <input class="input" id="add-username" type="text" placeholder="e.g. name@email.com" autocomplete="off">
      </div>

      <div class="field">
        <label class="field__label" for="add-password">Password</label>
        <div class="field__control">
          <input class="input input--with-icon" id="add-password" type="password" placeholder="Enter or generate a password" autocomplete="new-password">
          <button type="button" class="field__icon-btn" data-toggle-visibility="add-password" aria-label="Show password">
            <svg><use href="#ic-eye"/></svg>
          </button>
        </div>
        <div class="strength-meter" id="add-strength-meter">
          <div class="strength-meter__seg"></div><div class="strength-meter__seg"></div>
          <div class="strength-meter__seg"></div><div class="strength-meter__seg"></div>
        </div>
        <div class="row-between" style="margin-top:8px;">
          <span class="strength-label" id="add-strength-label" style="margin:0;">Strength</span>
          <button type="button" class="btn-ghost" id="btn-open-generator" style="padding:4px 8px;font-size:13.5px;">
            <svg style="width:15px;height:15px;"><use href="#ic-refresh"/></svg> Generate
          </button>
        </div>
      </div>

      <div class="field">
        <label class="field__label" for="add-category">Category</label>
        <select class="select" id="add-category"></select>
      </div>

      <div class="field">
        <label class="field__label" for="add-notes">Notes</label>
        <textarea class="textarea" id="add-notes" placeholder="Optional notes"></textarea>
      </div>

      <div class="field">
        <label class="field__label">Icon</label>
        <div class="row glass" style="padding:12px;border-radius:16px;">
          <div class="entry-card__icon" id="add-icon-preview" style="width:44px;height:44px;">
            <svg style="width:20px;height:20px;color:var(--text-tertiary);"><use href="#ic-globe"/></svg>
          </div>
          <div class="stack" style="gap:2px;">
            <span style="font-size:13.5px;font-weight:600;">Auto-detected from URL</span>
            <span style="font-size:12px;color:var(--text-tertiary);">Or upload a custom icon</span>
          </div>
          <div class="spacer"></div>
          <button type="button" class="btn-secondary btn-sm" id="btn-upload-icon" style="border-radius:999px;">Upload</button>
          <input type="file" id="add-icon-file" accept="image/*" class="file-input-hidden">
        </div>
      </div>

      <button type="submit" class="btn btn-primary" style="margin-top:8px;">Save Password</button>
    </form>
  </section>

  <!-- ================= CATEGORIES ================= -->
  <section id="screen-categories" class="screen" hidden>
    <div class="topbar">
      <div>
        <h1 class="topbar__title">Categories</h1>
        <p class="topbar__subtitle">Browse by type</p>
      </div>
    </div>

    <div class="category-grid" id="category-grid"></div>

    <footer class="app-footer" data-footer></footer>
  </section>

  <!-- ================= CATEGORY DETAIL (filtered list) ================= -->
  <section id="screen-category-detail" class="screen" hidden data-hide-nav>
    <div class="topbar">
      <button class="icon-btn" id="btn-category-back" aria-label="Back"><svg><use href="#ic-chevron-left"/></svg></button>
      <h1 class="topbar__title" id="category-detail-title" style="font-size:19px;">Category</h1>
      <div style="width:40px;"></div>
    </div>
    <div class="entry-list" id="category-detail-list"></div>
    <div class="empty-state" id="category-detail-empty" hidden>
      <div class="empty-state__icon"><svg><use href="#ic-folder"/></svg></div>
      <h2 class="empty-state__title">Nothing here yet</h2>
      <p class="empty-state__text">Items you save in this category will appear here.</p>
    </div>
  </section>

  <!-- ================= SETTINGS ================= -->
  <section id="screen-settings" class="screen" hidden>
    <div class="topbar">
      <div>
        <h1 class="topbar__title">Settings</h1>
        <p class="topbar__subtitle">Vault &amp; security</p>
      </div>
    </div>

    <p class="section-label">Security</p>
    <div class="settings-card glass settings-group">
      <div class="settings-row" id="row-change-password">
        <div class="settings-row__icon"><svg><use href="#ic-key"/></svg></div>
        <span class="settings-row__label">Change Master Password</span>
        <span class="settings-row__chevron"><svg><use href="#ic-chevron-right"/></svg></span>
      </div>
      <div class="settings-row" id="row-autolock">
        <div class="settings-row__icon"><svg><use href="#ic-clock"/></svg></div>
        <span class="settings-row__label">Auto-Lock</span>
        <span class="settings-row__value" id="autolock-value">5 minutes</span>
        <span class="settings-row__chevron"><svg><use href="#ic-chevron-right"/></svg></span>
      </div>
      <div class="settings-row" id="row-lock-now">
        <div class="settings-row__icon"><svg><use href="#ic-lock"/></svg></div>
        <span class="settings-row__label">Lock Vault Now</span>
        <span class="settings-row__chevron"><svg><use href="#ic-chevron-right"/></svg></span>
      </div>
    </div>

    <p class="section-label">Backup</p>
    <div class="settings-card glass settings-group">
      <div class="settings-row" id="row-export">
        <div class="settings-row__icon"><svg><use href="#ic-download"/></svg></div>
        <span class="settings-row__label">Export Encrypted Backup</span>
        <span class="settings-row__chevron"><svg><use href="#ic-chevron-right"/></svg></span>
      </div>
      <div class="settings-row" id="row-import">
        <div class="settings-row__icon"><svg><use href="#ic-upload"/></svg></div>
        <span class="settings-row__label">Import Encrypted Backup</span>
        <span class="settings-row__chevron"><svg><use href="#ic-chevron-right"/></svg></span>
      </div>
      <input type="file" id="import-file-input" accept="application/json,.json" class="file-input-hidden">
    </div>

    <p class="section-label">Data</p>
    <div class="settings-card glass settings-group">
      <div class="settings-row" id="row-clear-data">
        <div class="settings-row__icon is-danger"><svg><use href="#ic-trash"/></svg></div>
        <span class="settings-row__label" style="color:var(--danger);">Clear All Data</span>
        <span class="settings-row__chevron"><svg><use href="#ic-chevron-right"/></svg></span>
      </div>
    </div>

    <p class="section-label">About</p>
    <div class="settings-card glass settings-group">
      <div class="settings-row" style="cursor:default;">
        <div class="settings-row__icon"><svg><use href="#ic-info"/></svg></div>
        <span class="settings-row__label">App Information</span>
        <span class="settings-row__value">v1.0</span>
      </div>
    </div>

    <footer class="app-footer" data-footer></footer>
  </section>

  <!-- ================= PASSWORD DETAILS ================= -->
  <section id="screen-detail" class="screen" hidden data-hide-nav>
    <div class="topbar">
      <button class="icon-btn" id="btn-detail-back" aria-label="Back"><svg><use href="#ic-chevron-left"/></svg></button>
      <div style="width:40px;"></div>
      <button class="icon-btn" id="btn-detail-edit" aria-label="Edit"><svg><use href="#ic-edit"/></svg></button>
    </div>

    <div class="detail-header">
      <div class="detail-header__icon" id="detail-icon">
        <svg style="width:28px;height:28px;color:var(--text-tertiary);"><use href="#ic-globe"/></svg>
      </div>
      <h1 class="detail-header__title" id="detail-title">Website</h1>
      <p class="detail-header__subtitle" id="detail-url">example.com</p>
    </div>

    <div class="detail-card glass">
      <div class="detail-row">
        <div class="detail-row__body">
          <p class="detail-row__label">Username</p>
          <p class="detail-row__value" id="detail-username">&mdash;</p>
        </div>
        <div class="detail-row__actions">
          <button class="icon-btn" data-copy="username" aria-label="Copy username"><svg><use href="#ic-copy"/></svg></button>
        </div>
      </div>
      <div class="detail-row">
        <div class="detail-row__body">
          <p class="detail-row__label">Password</p>
          <p class="detail-row__value is-mono" id="detail-password">••••••••••••</p>
        </div>
        <div class="detail-row__actions">
          <button class="icon-btn" id="btn-toggle-detail-password" aria-label="Show password"><svg><use href="#ic-eye"/></svg></button>
          <button class="icon-btn" data-copy="password" aria-label="Copy password"><svg><use href="#ic-copy"/></svg></button>
        </div>
      </div>
    </div>

    <div class="detail-card glass" id="detail-notes-card">
      <div class="detail-row">
        <div class="detail-row__body">
          <p class="detail-row__label">Category</p>
          <p class="detail-row__value" id="detail-category">General</p>
        </div>
      </div>
      <div class="detail-row" id="detail-notes-row">
        <div class="detail-row__body">
          <p class="detail-row__label">Notes</p>
          <p class="detail-row__value" id="detail-notes">&mdash;</p>
        </div>
      </div>
      <div class="detail-row">
        <div class="detail-row__body">
          <p class="detail-row__label">Last Updated</p>
          <p class="detail-row__value" id="detail-updated">&mdash;</p>
        </div>
      </div>
    </div>

    <button class="btn btn-danger" id="btn-delete-entry" style="margin-top:6px;">
      <svg style="width:17px;height:17px;"><use href="#ic-trash"/></svg> Delete Password
    </button>
  </section>

  <!-- ================= BOTTOM NAV ================= -->
  <nav class="tabbar glass" id="tabbar">
    <button class="navitem" data-nav="vault">
      <svg><use href="#ic-key"/></svg><span>Vault</span>
    </button>
    <button class="navitem" data-nav="categories">
      <svg><use href="#ic-grid"/></svg><span>Categories</span>
    </button>
    <button class="navitem navitem--fab" data-nav="add">
      <span class="navitem__fab-circle"><svg><use href="#ic-plus"/></svg></span>
      <span>Add</span>
    </button>
    <button class="navitem" data-nav="settings">
      <svg><use href="#ic-gear"/></svg><span>Settings</span>
    </button>
  </nav>

  <!-- ================= TOAST ================= -->
  <div class="toast" id="toast">
    <svg><use href="#ic-check"/></svg>
    <span id="toast-text">Saved</span>
  </div>

  <!-- ================= SHEET BACKDROP ================= -->
  <div class="sheet-backdrop" id="sheet-backdrop"></div>

  <!-- ---- Password generator sheet ---- -->
  <div class="sheet" id="sheet-generator">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Password Generator</h2>

    <div class="generator-output">
      <span class="generator-output__text" id="generator-output">—</span>
      <button class="icon-btn" id="btn-generator-refresh" aria-label="Regenerate"><svg><use href="#ic-refresh"/></svg></button>
      <button class="icon-btn" id="btn-generator-copy" aria-label="Copy"><svg><use href="#ic-copy"/></svg></button>
    </div>

    <div class="generator-row">
      <span class="generator-row__label">Length: <strong id="generator-length-value">20</strong></span>
    </div>
    <input type="range" class="range" id="generator-length" min="8" max="48" value="20">

    <div class="generator-row"><span class="generator-row__label">Uppercase (A-Z)</span>
      <label class="switch"><input type="checkbox" id="generator-upper" checked><span class="switch__track"></span></label>
    </div>
    <div class="generator-row"><span class="generator-row__label">Lowercase (a-z)</span>
      <label class="switch"><input type="checkbox" id="generator-lower" checked><span class="switch__track"></span></label>
    </div>
    <div class="generator-row"><span class="generator-row__label">Numbers (0-9)</span>
      <label class="switch"><input type="checkbox" id="generator-numbers" checked><span class="switch__track"></span></label>
    </div>
    <div class="generator-row"><span class="generator-row__label">Symbols (!@#$)</span>
      <label class="switch"><input type="checkbox" id="generator-symbols" checked><span class="switch__track"></span></label>
    </div>
    <div class="generator-row"><span class="generator-row__label">Exclude ambiguous (I, l, 1, O, 0)</span>
      <label class="switch"><input type="checkbox" id="generator-ambiguous" checked><span class="switch__track"></span></label>
    </div>

    <button class="btn btn-primary" id="btn-generator-use" style="margin-top:14px;">Use This Password</button>
  </div>

  <!-- ---- Change master password sheet ---- -->
  <div class="sheet" id="sheet-change-password">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Change Master Password</h2>
    <form id="form-change-password" novalidate>
      <div class="field">
        <label class="field__label" for="cp-current">Current password</label>
        <input class="input" id="cp-current" type="password" autocomplete="current-password" required>
      </div>
      <div class="field">
        <label class="field__label" for="cp-new">New password</label>
        <input class="input" id="cp-new" type="password" autocomplete="new-password" required>
      </div>
      <div class="field">
        <label class="field__label" for="cp-confirm">Confirm new password</label>
        <input class="input" id="cp-confirm" type="password" autocomplete="new-password" required>
        <div class="field__error" id="cp-error">Please check your entries and try again.</div>
      </div>
      <button type="submit" class="btn btn-primary">Update Password</button>
    </form>
  </div>

  <!-- ---- Auto-lock sheet ---- -->
  <div class="sheet" id="sheet-autolock">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Auto-Lock After</h2>
    <div class="stack" id="autolock-options"></div>
  </div>

  <!-- ---- Export backup sheet ---- -->
  <div class="sheet" id="sheet-export">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Export Encrypted Backup</h2>
    <div class="callout callout--info">
      <svg><use href="#ic-info"/></svg>
      <p>The backup file stays fully encrypted. Restoring it requires the master password that was active when it was created.</p>
    </div>
    <button class="btn btn-primary" id="btn-confirm-export">
      <svg style="width:17px;height:17px;"><use href="#ic-download"/></svg> Download Backup File
    </button>
  </div>

  <!-- ---- Import backup sheet ---- -->
  <div class="sheet" id="sheet-import">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Import Encrypted Backup</h2>
    <div class="callout callout--warning">
      <svg><use href="#ic-warning"/></svg>
      <p><strong>This replaces your current vault.</strong> Unlock afterward using the master password that created the backup.</p>
    </div>
    <p class="field__hint" id="import-file-name" style="margin:0 0 16px 4px;">No file selected.</p>
    <div class="stack">
      <button class="btn btn-secondary" id="btn-choose-import-file">Choose Backup File</button>
      <button class="btn btn-primary" id="btn-confirm-import" disabled>Replace Vault</button>
    </div>
  </div>

  <!-- ---- Clear data confirm sheet ---- -->
  <div class="sheet" id="sheet-clear-data">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Clear All Data</h2>
    <div class="callout callout--danger">
      <svg><use href="#ic-warning"/></svg>
      <p><strong>This cannot be undone.</strong> Every saved password and your master password will be permanently deleted from this device.</p>
    </div>
    <div class="stack">
      <button class="btn btn-danger" id="btn-confirm-clear">Delete Everything</button>
      <button class="btn btn-secondary" id="btn-cancel-clear">Cancel</button>
    </div>
  </div>

  <!-- ---- Delete entry confirm sheet ---- -->
  <div class="sheet" id="sheet-delete-entry">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Delete Password</h2>
    <p class="lock-subtitle" style="margin-bottom:20px;" id="delete-entry-message">This will permanently remove this login from your vault.</p>
    <div class="stack">
      <button class="btn btn-danger" id="btn-confirm-delete-entry">Delete</button>
      <button class="btn btn-secondary" id="btn-cancel-delete-entry">Cancel</button>
    </div>
  </div>

  <!-- ---- Forgot password sheet ---- -->
  <div class="sheet" id="sheet-forgot">
    <div class="sheet__handle"></div>
    <h2 class="sheet__title">Master Password Recovery</h2>
    <div class="callout callout--danger">
      <svg><use href="#ic-warning"/></svg>
      <p><strong>Your data cannot be recovered without the master password.</strong> Encryption keys are derived only from it and are never stored anywhere.</p>
    </div>
    <p class="field__hint" style="margin:0 0 16px 4px;">The only way forward is to clear the vault and start fresh, which permanently deletes everything currently saved.</p>
    <div class="stack">
      <button class="btn btn-danger" id="btn-forgot-clear">Clear Vault and Start Over</button>
      <button class="btn btn-secondary" id="btn-forgot-cancel">Cancel</button>
    </div>
  </div>

</div>

<script src="js/crypto.js"></script>
<script src="js/db.js"></script>
<script src="js/app.js"></script>
</body>
</html>
